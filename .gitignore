# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# macOS metadata
.DS_Store

# Data outputs (large files; keep raw source data out of git)
*.parquet
*.csv

# Raw/cleaned/analysis data layer — immutable per CLAUDE.md, never edited or committed;
# includes files >100MB (GitHub hard limit) such as CDD weather rasters and shapefiles.
01_data/

# Jupyter checkpoints
.ipynb_checkpoints/

# Credentials / secrets — never commit these
.env
.env.*
!.env.example
*.key

# LLM-wiki drift marker (local)
.claude/.wiki_sync_state
