library(readr)
library(dplyr)
df <- read_csv("../../01_data/4_model/ercot_regression_model_dataset.csv", col_types = cols(datetime = col_skip(), year = col_character()))
head(df)
# set season and year as categorical variables
df$season <- as.factor(df$season)
df$year   <- as.factor(df$year)
summary(df)
# check correlation among numerical variables
install.packages("corrplot")  # if not installed
library(corrplot)
cor_matrix <- cor(df %>% select(where(is.numeric)), use = "complete.obs")
print(cor_matrix)
corrplot(cor_matrix, method = "circle")  # or "color", "number", "shade", "ellipse"
cor_by_year <- df %>%
group_by(year) %>%
group_split() %>%
setNames(sort(unique(df$year))) %>%
lapply(function(x) {
x %>% select(where(is.numeric)) %>% cor(use = "complete.obs")
})
library(readr)
library(dplyr)
library(corrplot)
library(car)
df <- read_csv("../../01_data/4_model/ercot_regression_model_dataset.csv", col_types = cols(datetime = col_skip(), year = col_character()))
head(df)
# check correlation among numerical variables
cor_matrix <- cor(df %>% select(where(is.numeric)), use = "complete.obs")
print(cor_matrix)
corrplot(cor_matrix, method = "circle")  # or "color", "number", "shade", "ellipse"
cor_by_year <- df %>%
group_by(year) %>%
group_split() %>%
setNames(sort(unique(df$year))) %>%
lapply(function(x) {
x %>% select(where(is.numeric)) %>% cor(use = "complete.obs")
})
# View correlation matrix for a specific year
cor_by_year[["2023"]]
# View all
cor_by_year
